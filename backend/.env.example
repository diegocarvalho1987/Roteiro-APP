GOOGLE_SHEETS_ID=
# JSON da service account em uma linha, codificado em base64
GOOGLE_SERVICE_ACCOUNT_JSON=

JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24

# Origens CORS separadas por vírgula (URL do front na Vercel)
CORS_ORIGINS=http://localhost:5173

VENDEDOR_EMAIL=rafael@example.com
VENDEDOR_PASSWORD_HASH=
PROPRIETARIA_EMAIL=proprietaria@example.com
PROPRIETARIA_PASSWORD_HASH=

# Opcional: em desenvolvimento, senhas em texto (não use em produção)
# ALLOW_PLAIN_PASSWORDS=1
# VENDEDOR_PASSWORD=secret
# PROPRIETARIA_PASSWORD=secret
